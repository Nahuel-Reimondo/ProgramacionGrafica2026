Shader "TextureWater"
{
	Properties
	{
		_Texture0("Texture 0", 2D) = "white" {}
		_Tilling("Tilling", Vector) = (0,0,0,0)
		_PannerSpeed("PannerSpeed", Vector) = (0,0,0,0)
		[HideInInspector] _texcoord( "", 2D ) = "white" {}
		[HideInInspector] __dirty( "", Int ) = 1
	}

	SubShader
	{
		Tags{ "RenderType" = "Opaque"  "Queue" = "Geometry+0" }
		Cull Back
		CGPROGRAM
		#include "UnityShaderVariables.cginc"
		#pragma target 3.0
		#pragma surface surf Standard keepalpha addshadow fullforwardshadows 
		struct Input
		{
			float2 uv_texcoord;
		};

		uniform sampler2D _Texture0;
		uniform float2 _PannerSpeed;
		uniform float2 _Tilling;

		void surf( Input i , inout SurfaceOutputStandard o )
		{
			float2 uv_TexCoord4 = i.uv_texcoord * _Tilling;
			float2 panner3 = ( 1.0 * _Time.y * _PannerSpeed + uv_TexCoord4);
			o.Albedo = tex2D( _Texture0, panner3 ).rgb;
			o.Alpha = 1;
		}

		ENDCG
	}
	Fallback "Diffuse"
	CustomEditor "ASEMaterialInspector"
}
